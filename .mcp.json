{
  "mcpServers": {
    "github": {
      "type": "stdio",
      "command": "C:/Users/%USERNAME%/go/bin/github-mcp-server.exe",
      "args": [
        "stdio"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_AI_MCP_PAT}"
      }
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      }
    },
    "mcpserver-audit": {
      "type": "stdio",
      "command": "python",
      "args": [
        "C:/Users/%USERNAME%/tools/mcpserver-audit/server.py"
      ]
    }
  }
}