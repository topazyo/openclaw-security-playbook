{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(pytest:*)",
      "Bash(python3:*)",
      "Bash(docker inspect:*)",
      "Bash(openssl s_client:*)",
      "Bash(jq:*)",
      "Bash(wc:*)",
      "Bash(grep:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Read(.github/audit/**)",
      "Read(tests/**)",
      "Read(detections/**)",
      "Write(.github/audit/**)",
      "Write(AUDIT_ROADMAP.md)",
      "Write(BATCH_EXECUTION_PLAN.md)",
      "Write(DEBT_INVENTORY_ACTIVE.md)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(docker run --privileged*)",
      "Bash(chmod 777*)",
      "Bash(sudo *)",
      "Bash(pip install *)",
      "Bash(npm install *)",
      "Bash(pytest tests/ *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-tool-use.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-tool-use.sh"
          }
        ]
      }
    ]
  },
  "env": {
    "PYTHONDONTWRITEBYTECODE": "1",
    "PYTHONUNBUFFERED": "1"
  },
  "includeCoAuthoredBy": true,
  "cleanupPeriodDays": 30
}
